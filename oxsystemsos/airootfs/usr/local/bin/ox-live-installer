#!/usr/bin/env bash
set -euo pipefail

lock_file="${XDG_RUNTIME_DIR:-/tmp}/.ox-installer-launched"
if [[ -e "${lock_file}" ]]; then
  exit 0
fi
touch "${lock_file}"

title="OXSystemsOS Installer"
prompt="Start OXSystemsOS installation now?"

if command -v zenity >/dev/null 2>&1; then
  if ! zenity --question \
      --title="${title}" \
      --text="${prompt}" \
      --ok-label="Install now" \
      --cancel-label="Later" \
      --width=420; then
    exit 0
  fi
fi

if command -v gnome-terminal >/dev/null 2>&1; then
  exec gnome-terminal --title="${title}" -- bash -lc '
    echo "Launching archinstall..."
    sudo archinstall
    echo
    echo "Installer finished. Press Enter to close."
    read -r
  '
fi

exec bash -lc 'sudo archinstall'
