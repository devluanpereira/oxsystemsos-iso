#!/usr/bin/env bash
set -euo pipefail

expected="/run/archiso/bootmnt/ox/x86_64/airootfs.erofs"
link_path="/tmp/oxsystemsos-airootfs.erofs"

candidate=""
search_roots=(
  /run/archiso/bootmnt
  /run/archiso/isodevice
  /run/archiso
  /run/media
  /media
  /mnt
)

if [[ -r "${expected}" ]]; then
  candidate="${expected}"
else
  for root in "${search_roots[@]}"; do
    [[ -d "${root}" ]] || continue
    while IFS= read -r path; do
      case "${path}" in
        */ox/x86_64/airootfs.erofs)
          candidate="${path}"
          break 2
          ;;
      esac
      if [[ -z "${candidate}" ]]; then
        candidate="${path}"
      fi
    done < <(find "${root}" -maxdepth 12 -type f -name 'airootfs.erofs' 2>/dev/null | sort)
  done
fi

if [[ -z "${candidate}" ]]; then
  echo "Unable to locate live rootfs image (airootfs.erofs)." >&2
  exit 1
fi

ln -sfn "${candidate}" "${link_path}"
